  const H    = 0.52;    // uniform height — taller
  const S    = 0.68;    // square chamber side — bigger
  const SP   = 0.68;    // spine = same size as chamber for visual match
  const CC   = 0xD4900A;

  // ── Central spine — short connector at cross center ──────
  mkPart(new THREE.BoxGeometry(SP, H, SP),
    vc.face, 0.40, group, vc, td, 'frame'
  ).position.set(0, CY, 0);

  // ── chamber_0: back arm, flush with spine back ────────────
  if(!(chs.length && chs[0]===null)){
    const ch0 = mkPart(new THREE.BoxGeometry(S, H, S), CC, 0.40, group, vc, td, 'chamber_0');
    ch0.position.set(0, CY, -(SP/2 + S/2));
    ch0.userData.localBaseY = CY;
  }

  // ── chamber_1: left arm, flush with spine left ────────────
  if(!(chs.length && chs[1]===null)){
    const ch1 = mkPart(new THREE.BoxGeometry(S, H, S), CC, 0.40, group, vc, td, 'chamber_1');
    ch1.position.set(-(SP/2 + S/2), CY, 0);
    ch1.userData.localBaseY = CY;
  }

  // ── chamber_2: right arm, mirror ──────────────────────────
  if(!(chs.length && chs[2]===null)){
    const ch2 = mkPart(new THREE.BoxGeometry(S, H, S), CC, 0.40, group, vc, td, 'chamber_2');
    ch2.position.set(SP/2 + S/2, CY, 0);
    ch2.userData.localBaseY = CY;
  }

  // ── Load ports (3) — front of spine ───────────────────────
  [-0.26, 0, 0.26].forEach(x => {
    mkPart(new THREE.BoxGeometry(0.24, 0.22, 0.20),
      vc.face, 0.40, group, vc, td, 'frame')
      .position.set(x, 0.22, SP/2 + 0.14);
  });
}

function buildEpis(group, vc, td, chs=[]){
  const CY   = 0.55;   // shared Y center
  const H    = 0.46;   // uniform height
  const FW   = 0.56;   // frame spine width
  const FD   = 1.40;   // frame spine depth
  const CH_W = 0.48;   // chamber width
  const CH_D = 0.54;   // chamber depth
  const GAP  = 0.04;   // gap between stacked chambers

  const FX = 0;
  const FZ = -(0.12);  // spine centered slightly back to leave room for load ports front

  // ── Frame spine (thin center bar) ────────────────────────
  mkPart(new THREE.BoxGeometry(FW, H, FD),
    vc.face, 0.40, group, vc, td, 'frame'
  ).position.set(FX, CY, FZ);

  // ── Stacked chamber positions (shared Z values) ───────────
  // upper chamber center Z: back face of spine + half CH_D
  const upZ = FZ - FD/2 + CH_D/2;
  // lower chamber center Z: upper front face + GAP + half CH_D
  const loZ = upZ + CH_D/2 + GAP + CH_D/2;

  // Left side chambers (–X from spine); skip if slot is null
  const lX = FX - FW/2 - CH_W/2;
  if(!(chs.length && chs[0]===null)){
    const ch0 = mkPart(new THREE.BoxGeometry(CH_W, H, CH_D), vc.top, 0.35, group, vc, td, 'chamber_0');
    ch0.position.set(lX, CY, upZ); ch0.userData.localBaseY = CY;
  }
  if(!(chs.length && chs[1]===null)){
    const ch1 = mkPart(new THREE.BoxGeometry(CH_W, H, CH_D), vc.top, 0.35, group, vc, td, 'chamber_1');
    ch1.position.set(lX, CY, loZ); ch1.userData.localBaseY = CY;
  }

  // Right side chambers (+X from spine)
  const rX = FX + FW/2 + CH_W/2;
  if(!(chs.length && chs[2]===null)){
    const ch2 = mkPart(new THREE.BoxGeometry(CH_W, H, CH_D), vc.top, 0.35, group, vc, td, 'chamber_2');
    ch2.position.set(rX, CY, upZ); ch2.userData.localBaseY = CY;
  }
  if(!(chs.length && chs[3]===null)){
    const ch3 = mkPart(new THREE.BoxGeometry(CH_W, H, CH_D), vc.top, 0.35, group, vc, td, 'chamber_3');
    ch3.position.set(rX, CY, loZ); ch3.userData.localBaseY = CY;
  }

  // ── Load port bar — wide, front of tool ──────────────────
  mkPart(new THREE.BoxGeometry(FW + CH_W*2, 0.26, 0.28),
    vc.face, 0.50, group, vc, td, 'frame'
  ).position.set(FX, 0.22, FZ + FD/2 + 0.16);
}

