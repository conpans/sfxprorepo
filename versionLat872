  },

  // ── vec demo: slot 0 (back/top arm) null — only left + right chambers installed ──
  // slot 0 = back arm (top, above TM)  →  null = not installed
  // slot 1 = left arm                  →  active
  // slot 2 = right arm                 →  active
  'PCVD-102': {
