function buildAlt(group, vc, td, chs=[]){
  // Transfer module: octagonal cylinder
  mkPart(new THREE.CylinderGeometry(0.38,0.38,0.30,8),
    vc.top, 0.30, group, vc, td, 'frame'
  ).position.set(0, 0.64, -0.18);

  // Lower frame body
  mkPart(new THREE.BoxGeometry(1.10,0.22,0.46),
    vc.face, 0.40, group, vc, td, 'frame'
  ).position.set(0, 0.37, 0.03);

  // Process chambers (4) — flush against TM sides; skip null slots
  [[-0.62,0,0],[-0.40,0,-0.60],[0.40,0,-0.60],[0.62,0,0]].forEach((off,i)=>{
    if(chs.length && chs[i] === null) return;
    const baseY=0.64;
    const ch=mkPart(new THREE.BoxGeometry(0.48,0.44,0.48),
      vc.face, 0.40, group, vc, td, `chamber_${i}`
    );
    ch.position.set(off[0], baseY, -0.18+off[2]);
    ch.userData.localBaseY=baseY;
  });

  // Load ports (3)
  [-0.44,0,0.44].forEach(x=>{
    mkPart(new THREE.BoxGeometry(0.36,0.24,0.26),
      vc.shadow, 0.50, group, vc, td, 'frame'
    ).position.set(x, 0.18, 0.46);
  });
}

function buildTri(group, vc, td, chs=[]){
  const tmX=0, tmY=0.70, tmZ=-0.15;

  // Transfer module: hexagonal cylinder (flat-top)
  mkPart(new THREE.CylinderGeometry(0.42,0.42,0.28,6),
    vc.top, 0.28, group, vc, td, 'frame'
  ).position.set(tmX, tmY, tmZ);

  // Lower frame body — sits clearly below the chamber layer
  mkPart(new THREE.BoxGeometry(1.20,0.20,0.50),
    vc.face, 0.40, group, vc, td, 'frame'
  ).position.set(0, 0.30, 0.05);

  // 4 petal chambers: 9-11-1-3 o'clock (left, upper-left, upper-right, right)
  const petalR=0.71;
  [270,330,30,90].forEach((deg,i)=>{
    if(chs.length && chs[i] === null) return;
    const th=deg*Math.PI/180;
    const ch=mkPart(new THREE.BoxGeometry(0.38,0.40,0.58),
      vc.face, 0.40, group, vc, td, `chamber_${i}`
    );
    ch.position.set(tmX+petalR*Math.sin(th), tmY, tmZ-petalR*Math.cos(th));
    ch.rotation.y=-th;
    ch.userData.localBaseY=tmY;
  });

}

function buildVec(group, vc, td, chs=[]){
