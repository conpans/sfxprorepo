function mkFloorTex(fill){
  const sz=256,can=document.createElement('canvas');can.width=sz;can.height=sz;
  const ctx=can.getContext('2d');
  ctx.fillStyle=fill;ctx.fillRect(0,0,sz,sz);
  ctx.strokeStyle='rgba(136,153,183,0.38)';ctx.lineWidth=3;ctx.strokeRect(1.5,1.5,sz-3,sz-3);
  const tex=new THREE.CanvasTexture(can);
  tex.wrapS=tex.wrapT=THREE.RepeatWrapping;
  tex.generateMipmaps=true;tex.minFilter=THREE.LinearMipmapLinearFilter;
  tex.magFilter=THREE.LinearFilter;
  tex.anisotropy=Math.min(4,R.capabilities.getMaxAnisotropy());
