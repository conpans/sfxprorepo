// mkPart — create one cluster part, register in TM + TD, attach to group
function mkPart(geo, colorHex, roughness, group, vc, td, partType){
  const mat = new THREE.MeshStandardMaterial({color:colorHex, roughness, metalness:0.0});
  const mesh = new THREE.Mesh(geo, mat);
  mesh.castShadow = true;
  mesh.userData.vc        = vc;
  mesh.userData.baseColor = colorHex;
  mesh.userData.groupRef  = group;
  mesh.userData.partType  = partType;
  TM.push(mesh);
  TD.set(mesh, {...td, partType});
  group.add(mesh);
  return mesh;
}

