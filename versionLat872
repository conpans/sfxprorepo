<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CVD Central — Fab Floor Map</title>
<style>
/* ================================================================
   CVD CENTRAL — FAB FLOOR MAP
   Tool location, details panel, and search.
================================================================ */

:root {
–lp-w:    292px;
–rp-w:    344px;
–tb-h:     48px;

–white:      #ffffff;
–bg:         #F2F4F7;
–bg-subtle:  #F8F9FB;
–panel-bg:   #ffffff;
–border:     #E2E8F0;
–border-sub: #EDF1F7;
–map-bg:     #EDEEF1;

–txt-primary:   #1C2B4A;
–txt-secondary: #5A6882;
–txt-muted:     #8A9BB0;

–accent:    #0078D4;
–accent-lt: rgba(0,120,212,0.08);

–v-prod: #1A6B35;   /* Production — deep green */
–v-eng:  #5C4A9E;   /* Engineering — slate violet */

–fs-base:    17px;
–fs-sm:      16px;
–fs-xs:      15px;
–fs-label:   13px;
–fs-heading: 18px;
–fs-large:   22px;

–r-sm: 4px;  –r: 6px;  –r-lg: 9px;
–font: ‘Segoe UI’, system-ui, -apple-system, sans-serif;

–shadow-l:  1px 0 8px rgba(0,0,0,0.05), 4px 0 20px rgba(0,0,0,0.03);
–shadow-r: -1px 0 8px rgba(0,0,0,0.05),-4px 0 20px rgba(0,0,0,0.03);

–page-bg:  #EDEBE9;
–page-pad: 16px;
}

*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html,body{width:100%;height:100%;overflow:hidden}
body{
background:var(–page-bg);
font-family:var(–font);
font-size:var(–fs-base);
color:var(–txt-primary);
padding:var(–page-pad);
display:flex;
align-items:stretch;
}
button,input{font-family:var(–font)}
a{color:var(–accent)}

.webpart-host{width:100%;height:100%;display:flex;align-items:stretch}

.app-shell{
flex:1;
position:relative;
border-radius:16px;
overflow:hidden;
background:var(–white);
border:1px solid rgba(0,0,0,0.09);
box-shadow:0 1px 2px rgba(0,0,0,0.04),0 4px 10px rgba(0,0,0,0.06),0 12px 28px rgba(0,0,0,0.06);
container-type:size;
container-name:app;
}

/* ── APP GRID ── */
#app-grid{
display:grid;
grid-template-rows:var(–tb-h) 1fr;
width:100%;height:100%;
}

/* ── TOP BAR ── */
#top-bar{
display:flex;align-items:center;gap:10px;
padding:0 14px;
background:var(–white);
border-bottom:1px solid var(–border);
z-index:20;
}
#brand{display:flex;align-items:center;gap:8px;font-size:16px;font-weight:700;color:var(–txt-primary);letter-spacing:-0.01em}
#brand-icon{width:24px;height:24px;background:var(–accent);border-radius:5px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
#tb-sep{width:1px;height:18px;background:var(–border);margin:0 2px}
#tb-crumb{font-size:var(–fs-sm);color:var(–txt-secondary);display:flex;align-items:center;gap:5px}
#tb-crumb .here{color:var(–txt-primary);font-weight:500}
#tb-right{margin-left:auto;display:flex;align-items:center;gap:8px}
#btn-reset{font-size:var(–fs-xs);padding:4px 10px;border:1px solid var(–border);background:var(–white);color:var(–txt-secondary);border-radius:var(–r-sm);cursor:pointer}
#btn-reset:hover{background:var(–bg)}
#nav-drawer-btn{display:none;align-items:center;gap:5px;font-size:var(–fs-xs);padding:4px 10px;border:1px solid var(–border);background:var(–white);color:var(–txt-secondary);border-radius:var(–r-sm);cursor:pointer}

/* ── BODY GRID ── */
#body-grid{
display:grid;
grid-template-columns:var(–lp-w) 1fr var(–rp-w);
min-height:0;overflow:hidden;
}

/* ── LEFT PANEL ── */
#left-panel{
display:flex;flex-direction:column;overflow:hidden;
background:var(–panel-bg);
border-right:1px solid var(–border);
box-shadow:var(–shadow-l);
z-index:10;
}
#lp-controls{
flex-shrink:0;
padding:11px 13px 10px;
border-bottom:1px solid var(–border-sub);
background:var(–panel-bg);
}
#lp-eyebrow{
font-size:var(–fs-label);font-weight:700;letter-spacing:0.08em;
text-transform:uppercase;color:var(–txt-muted);margin-bottom:8px;
}
#search-wrap{position:relative}
#search-icon{position:absolute;left:9px;top:50%;transform:translateY(-50%);color:var(–txt-muted);pointer-events:none}
#search-input{
width:100%;padding:7px 10px 7px 30px;
border:1px solid var(–border);border-radius:var(–r-sm);
font-size:var(–fs-base);background:var(–bg);color:var(–txt-primary);outline:none;
transition:border-color 0.12s,box-shadow 0.12s;
}
#search-input:focus{border-color:var(–accent);box-shadow:0 0 0 2px var(–accent-lt);background:var(–white)}
#search-input::placeholder{color:var(–txt-muted)}

#lp-list-region{
flex:1;display:flex;flex-direction:column;overflow:hidden;
background:var(–bg-subtle);min-height:0;
}
#lp-list-label{
flex-shrink:0;
padding:7px 13px 4px;
font-size:var(–fs-label);font-weight:700;letter-spacing:0.07em;text-transform:uppercase;
color:var(–txt-muted);background:var(–bg-subtle);
}
#tool-list{flex:1;overflow-y:auto;padding-bottom:20px;min-height:0}
#tool-list::-webkit-scrollbar{width:3px}
#tool-list::-webkit-scrollbar-thumb{background:var(–border);border-radius:2px}

/* Tool row */
.tool-row{
display:flex;align-items:center;padding:9px 13px;gap:9px;
cursor:pointer;border-bottom:1px solid var(–border-sub);
transition:background 0.07s;
}
.tool-row:hover{background:rgba(255,255,255,0.8)}
.tool-row.sel{background:var(–accent-lt)}

.t-vendor-bar{width:4px;align-self:stretch;border-radius:2px;flex-shrink:0}
.t-vendor-bar.prod{background:var(–v-prod)}
.t-vendor-bar.eng{background:var(–v-eng)}

.t-info{flex:1;min-width:0}
.t-id{font-size:var(–fs-base);font-weight:600;color:var(–txt-primary);line-height:1.3}
.t-id.sel-id{color:var(–accent)}
.t-loc{font-size:var(–fs-xs);color:var(–txt-muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}

.t-chevron{font-size:15px;color:var(–txt-muted);transition:transform 0.18s;line-height:1;flex-shrink:0}
.tool-row.expanded .t-chevron{transform:rotate(90deg)}

/* Accordion */
.tool-accordion{
display:none;
background:rgba(242,244,247,0.6);
border-bottom:1px solid var(–border-sub);
}
.tool-accordion.open{display:block}

.chamber-row{
display:flex;align-items:center;gap:8px;
padding:6px 13px 6px 28px;
border-bottom:1px solid var(–border-sub);
cursor:pointer;transition:background 0.07s;
}
.chamber-row:hover{background:rgba(255,255,255,0.7)}
.chamber-row.sel{background:var(–accent-lt)}
.chamber-row:last-child{border-bottom:none}

.ch-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;border:1.5px solid var(–txt-muted)}
.ch-label{font-size:var(–fs-sm);color:var(–txt-secondary);flex:1;min-width:0}
.chamber-row.sel .ch-label{color:var(–accent);font-weight:600}

/* Vendor legend footer */
#lp-footer{
flex-shrink:0;padding:7px 13px;border-top:1px solid var(–border-sub);
background:var(–panel-bg);display:flex;align-items:center;gap:12px;
}
.lp-li{display:flex;align-items:center;gap:5px;font-size:var(–fs-xs);color:var(–txt-muted)}
.lp-vbar{width:4px;height:12px;border-radius:2px;flex-shrink:0}
.lp-vbar.prod{background:var(–v-prod)}.lp-vbar.eng{background:var(–v-eng)}

/* ── MAP ── */
#map-container{position:relative;overflow:hidden;background:var(–map-bg);min-width:0}
#cv{display:block}

/* ── RIGHT PANEL ── */
#right-panel{
display:flex;flex-direction:column;overflow:hidden;
background:var(–panel-bg);
border-left:1px solid var(–border);
box-shadow:var(–shadow-r);
z-index:10;
}
.rp-state{display:none;flex-direction:column;flex:1;overflow:hidden}
.rp-state.active{display:flex}
.rp-scroll{flex:1;overflow-y:auto;min-height:0;padding-bottom:20px}
.rp-scroll::-webkit-scrollbar{width:3px}
.rp-scroll::-webkit-scrollbar-thumb{background:var(–border);border-radius:2px}

/* State A — idle */
#rp-idle-body{
flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;
padding:32px 24px;text-align:center;gap:10px;
}
#rp-idle-body svg{color:var(–txt-muted);opacity:0.22;margin-bottom:6px}
#rp-idle-body h3{font-size:var(–fs-heading);font-weight:600;color:var(–txt-secondary)}
#rp-idle-body p{font-size:var(–fs-sm);color:var(–txt-muted);line-height:1.5;max-width:220px}

/* State B — tool selected */
#rp-sel-hd{
flex-shrink:0;padding:13px 15px 11px;
border-bottom:1px solid var(–border-sub);
}
.rp-back{
display:flex;align-items:center;gap:4px;
font-size:var(–fs-sm);color:var(–accent);cursor:pointer;
margin-bottom:8px;width:fit-content;
}
.rp-back:hover{text-decoration:underline}
.rp-tool-id{font-size:var(–fs-large);font-weight:700;letter-spacing:-0.02em;color:var(–txt-primary);margin-bottom:2px}
.rp-tool-meta{font-size:var(–fs-sm);color:var(–txt-secondary);margin-bottom:8px}

.vendor-badge{
display:inline-flex;align-items:center;gap:5px;
font-size:var(–fs-xs);font-weight:600;padding:3px 9px;border-radius:20px;
}
.vb-prod{background:rgba(26,107,53,0.09);color:var(–v-prod)}
.vb-eng{background:rgba(92,74,158,0.09);color:var(–v-eng)}

/* Pane sections */
.pane-sec{padding:13px 15px;border-bottom:1px solid var(–border-sub)}
.pane-sec:last-child{border-bottom:none}
.pane-sec-hd{
font-size:var(–fs-label);font-weight:700;letter-spacing:0.08em;
text-transform:uppercase;color:var(–txt-muted);margin-bottom:10px;
}

/* Workstation block */
.ws-block{
display:flex;align-items:center;gap:10px;
padding:10px 12px;background:var(–bg-subtle);
border:1px solid var(–border);border-radius:var(–r);
}
.ws-icon{width:28px;height:28px;border-radius:var(–r-sm);background:var(–accent-lt);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.ws-lbl{font-size:var(–fs-xs);color:var(–txt-muted);margin-bottom:1px}
.ws-name{font-size:var(–fs-base);font-weight:600;color:var(–txt-primary);font-family:‘Cascadia Code’,‘Consolas’,monospace;letter-spacing:0.01em}

/* Contact rows */
.contact-row{display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid var(–border-sub)}
.contact-row:last-child{border-bottom:none}
.contact-ico{width:28px;height:28px;border-radius:50%;background:var(–bg);border:1px solid var(–border);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:15px;color:var(–txt-muted)}
.contact-name{font-size:var(–fs-base);font-weight:600;color:var(–txt-primary);margin-bottom:1px}
.contact-detail{font-size:var(–fs-sm);color:var(–accent)}
.contact-detail a{color:var(–accent);text-decoration:none}
.contact-detail a:hover{text-decoration:underline}

/* Link rows — reference docs */
.link-list{display:flex;flex-direction:column}
.link-row{
display:flex;align-items:center;gap:10px;
padding:9px 0;border-bottom:1px solid var(–border-sub);
text-decoration:none;color:var(–txt-primary);transition:background 0.07s;
cursor:pointer;
}
.link-row:last-child{border-bottom:none}
.link-row:hover .link-title{color:var(–accent);text-decoration:underline}
.link-ico{
width:30px;height:30px;border-radius:var(–r-sm);
display:flex;align-items:center;justify-content:center;
flex-shrink:0;font-size:var(–fs-xs);font-weight:700;
}
.ico-sop{background:#EBF5E8;color:#1A5C1A}
.ico-jha{background:var(–t-crit-bg,#FDE8E0);color:#B83000}
.ico-ref{background:var(–bg);color:var(–txt-secondary);border:1px solid var(–border)}
.ico-photo{background:#EBF0FB;color:#1C4080}
.link-body{flex:1;min-width:0}
.link-title{font-size:var(–fs-base);font-weight:500;color:var(–txt-primary)}
.link-src{font-size:var(–fs-xs);color:var(–txt-muted);margin-top:1px}
.link-chev{font-size:14px;color:var(–txt-muted);flex-shrink:0}

.hier-frame{
font-size:var(–fs-base);font-weight:500;color:var(–txt-secondary);
padding:7px 0;
border-bottom:1px solid var(–border-sub);
display:flex;align-items:center;gap:7px;
}
.hier-frame:last-child{border-bottom:none}
.hier-ch{
font-size:var(–fs-sm);color:var(–txt-muted);
padding:3px 0 3px 22px;
display:flex;align-items:center;gap:6px;
}
.hier-ch-dot{width:5px;height:5px;border-radius:50%;background:var(–border);flex-shrink:0}

/* Meta rows */
.meta-row{display:flex;align-items:baseline;gap:8px;padding:5px 0;border-bottom:1px solid var(–border-sub);font-size:var(–fs-base)}
.meta-row:last-child{border-bottom:none}
.meta-lbl{flex:0 0 80px;font-size:var(–fs-sm);color:var(–txt-muted);flex-shrink:0}
.meta-val{flex:1;color:var(–txt-primary);font-weight:500}

/* ── TOOLTIP ── */
/* ── LEFT DRAWER (standard mode) ── */
#left-drawer{
display:none;position:absolute;top:0;left:0;bottom:0;width:var(–lp-w);
background:var(–panel-bg);border-right:1px solid var(–border);
box-shadow:4px 0 24px rgba(0,0,0,0.14);z-index:50;flex-direction:column;overflow:hidden;
}
#left-drawer.open{display:flex}
#drawer-backdrop{
display:none;position:absolute;inset:0;
background:rgba(0,0,0,0.12);z-index:40;
}
#drawer-backdrop.open{display:block}

/* ── RESPONSIVE ── */
@container app (max-width:900px){
#body-grid{grid-template-columns:1fr var(–rp-w)}
#left-panel{display:none}
#nav-drawer-btn{display:flex}
}
@container app (max-width:600px){
#body-grid{grid-template-columns:var(–lp-w) 1fr}
#right-panel{display:none}
#nav-drawer-btn{display:flex}
}

@keyframes slideLeft{from{transform:translateX(-100%)}to{transform:translateX(0)}}
@keyframes slideRight{from{transform:translateX(100%)}to{transform:translateX(0)}}
#left-panel{animation:slideLeft 0.24s cubic-bezier(0.22,1,0.36,1) both}
#right-panel{animation:slideRight 0.24s cubic-bezier(0.22,1,0.36,1) both}
</style>

