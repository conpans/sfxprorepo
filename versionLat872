// RENDER LOOP
// ============================================================
let lt=performance.now();
(function loop(now){
  requestAnimationFrame(loop);
  const dt=now-lt; lt=now;

  if(O.flyActive){
    O.flyT=Math.min(1,O.flyT+dt/O.flyDur);
    const e=easeIOC(O.flyT);
    O.tgt.lerpVectors(O.flyFrom.tgt,O.flyGoal.tgt,e);
    O.phi=O.flyFrom.phi+(O.flyGoal.phi-O.flyFrom.phi)*e;
    O.r  =O.flyFrom.r  +(O.flyGoal.r  -O.flyFrom.r  )*e;
    let dTh=O.flyGoal.theta-O.flyFrom.theta;
    while(dTh> Math.PI) dTh-=2*Math.PI;
    while(dTh<-Math.PI) dTh+=2*Math.PI;
    O.theta=O.flyFrom.theta+dTh*e;
    if(O.flyT>=1) O.flyActive=false;
  } else {
    O.idle+=dt;
    if(O.idle>O.idleD&&!O.drag&&!O.pan) O.theta+=O.idleS;
  }

  // Tool lift tween — operates on groups (all parts lift together)
  const LIFT=0.20;
  toolGroups.forEach(group=>{
    const tY=group.userData.liftActive ? LIFT : 0;
    const diff=tY-group.position.y;
    if(Math.abs(diff)>0.001) group.position.y+=diff*Math.min(1,dt*0.009);
  });
  // Chamber lift tween — selected chamber rises above the group
  if(selChamberMesh){
    const diff=(selChamberMesh.userData.localBaseY+CHAMBER_LIFT)-selChamberMesh.position.y;
    if(Math.abs(diff)>0.001) selChamberMesh.position.y+=diff*Math.min(1,dt*0.009);
  }
  // Previous chamber returns to its base Y
  if(prevChamberMesh){
    const diff=prevChamberMesh.userData.localBaseY-prevChamberMesh.position.y;
    if(Math.abs(diff)>0.001) prevChamberMesh.position.y+=diff*Math.min(1,dt*0.009);
    else prevChamberMesh=null;
  }

  // Selection bbox + HUD label + leader — update every frame to track lift tween
  if(selectedMeshes.size > 0 && selGroup){
    // Compute world bbox over all selected meshes
    _selBox3.makeEmpty();
    selectedMeshes.forEach(m=>{
      m.updateWorldMatrix(true,false);
      const b=new THREE.Box3().setFromObject(m);
      _selBox3.union(b);
    });

    // Label position: above bbox center
    const ctr = new THREE.Vector3();
    _selBox3.getCenter(ctr);
    const topY = _selBox3.max.y;
    const lblY = topY + 3.2;
    selLabelSprite.position.set(ctr.x, lblY, ctr.z);
    selLabelSprite.visible = true;

    // Leader: bottom point at bbox top, top point at label base
    _leaderPts[0]=ctr.x; _leaderPts[1]=topY+0.08; _leaderPts[2]=ctr.z;
    _leaderPts[3]=ctr.x; _leaderPts[4]=lblY-0.55;  _leaderPts[5]=ctr.z;
    _leaderGeo.attributes.position.needsUpdate=true;
    selLeader.visible=true;
  } else {
    selLabelSprite.visible=false;
    selLeader.visible=false;
  }

  uc();
  R.render(S,cam);
})(performance.now());

