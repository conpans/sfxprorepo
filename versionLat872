function applyMats(mesh, lerp, selected){
  const mats = Array.isArray(mesh.material) ? mesh.material : [mesh.material];
  if(selected){
    mats.forEach(m => m.color.set(SEL_COLOR));
  } else if(mesh.userData.baseColor !== undefined){
    // Cluster part — restore from stored base color
    const c = new THREE.Color(mesh.userData.baseColor).lerp(WHITE, lerp);
    mats.forEach(m => m.color.copy(c));
  } else {
    // Legacy 6-face box (fallback)
    const newMats = mkToolMat(mesh.userData.vc, lerp);
    mats.forEach((m,i) => m.color.copy(newMats[i] ? newMats[i].color : newMats[0].color));
    newMats.forEach(m => m.dispose());
  }
}

