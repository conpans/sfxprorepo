      f.chambers.some(ch => ch.toLowerCase().includes(q))
    );
    return idMatch || chamberMatch;
  });

  // Sort: building order (B→A→C) then row number then position
  const bldOrd = { B:0, A:1, C:2 };
  rows.sort((a,b) => {
    const ra = RM.get(a.ri), rb = RM.get(b.ri);
    const bo = (bldOrd[ra.b]??9) - (bldOrd[rb.b]??9);
    if(bo!==0) return bo;
    return (ra.n - rb.n) || (a.p - b.p);
  });

  if(!rows.length){
    list.innerHTML = `<div style="padding:20px 13px;font-size:15px;color:var(--txt-muted);text-align:center">No tools match.</div>`;
    return;
  }

  const html = rows.map(t => {
    const row = RM.get(t.ri);
    const isSel = t.id === uiSelectedTool;
    const meta = getToolMeta(t.id);

    // Auto-expand when search matches a chamber (not the tool ID itself)
    const idMatch = !q || t.id.toLowerCase().includes(q);
    const hasChamberMatch = q && !idMatch && meta.frames.some(f =>
      f.chambers.some(ch => ch && ch.toLowerCase().includes(q))
    );
    const isExpanded = uiExpandedTools.has(t.id) || hasChamberMatch;

    let accordion = '';
    if(isExpanded){
      const chamberRows = meta.frames.flatMap(f =>
        f.chambers
          .filter(ch => ch !== null && (idMatch || ch.toLowerCase().includes(q)))
          .map(ch => {
            const isCh = uiSelectedChamber && uiSelectedChamber.toolId===t.id && uiSelectedChamber.chamber===ch;
            return `<div class="chamber-row${isCh?' sel':''}" data-tool="${t.id}" data-frame="${f.label}" data-chamber="${ch}">
              <div class="ch-dot"></div>
              <div class="ch-label">${ch}</div>
            </div>`;
          })
      ).join('');
      if(chamberRows) accordion = `<div class="tool-accordion open">${chamberRows}</div>`;
    }

    return `
      <div class="tool-row${isSel?' sel':''}${isExpanded?' expanded':''}" data-id="${t.id}" data-v="${t.v}" data-bld="${row.b}" data-row="${row.n}" data-side="${t.s}">
        <div class="t-vendor-bar ${t.v}"></div>
        <div class="t-info">
          <div class="t-id${isSel?' sel-id':''}">${t.id}</div>
          <div class="t-loc">${BLDG_LABELS[row.b]||row.b} · Row ${row.n}</div>
        </div>
        <div class="t-chevron">›</div>
      </div>
      ${accordion}`;
  }).join('');

  list.innerHTML = html;

  list.querySelectorAll('.tool-row').forEach(el => {
    el.addEventListener('click', () => {
      const id = el.dataset.id;
      const data = {id, vendor:D.vn[el.dataset.v], bld:el.dataset.bld, row:el.dataset.row, side:el.dataset.side, v:el.dataset.v};
      if(uiExpandedTools.has(id) && uiSelectedTool === id){
        uiExpandedTools.delete(id);
        renderLeftPanel();
      } else {
        syncThreeSelection(id);
        selectTool(id, data);
      }
    });
  });

  // Chamber rows: drill into chamber detail state
  list.querySelectorAll('.chamber-row').forEach(el => {
    el.addEventListener('click', e => {
      e.stopPropagation();
      selectChamber(el.dataset.tool, el.dataset.frame, el.dataset.chamber);
    });
  });
}

// ============================================================
// SELECTION
// ============================================================
function selectTool(id, data){
  uiSelectedTool = id;
  uiSelectedChamber = null;
  uiExpandedTools.add(id);
  renderLeftPanel();
  renderToolPanel(id, data);
  setRpState('b');

  requestAnimationFrame(() => {
    const el = document.querySelector(`.tool-row[data-id="${id}"]`);
    if(el) el.scrollIntoView({block:'nearest', behavior:'smooth'});
  });
}

function selectChamber(toolId, frame, chamber){
  // Find the specific chamber mesh matching this chamber ID
  const meta = getToolMeta(toolId);
  const chIdx = meta.frames[0]?.chambers.indexOf(chamber);
  const chamberMesh = chIdx >= 0
    ? TM.find(m => TD.get(m)?.id===toolId && m.userData.partType===`chamber_${chIdx}`)
    : null;

  // Fly to tool + highlight the specific chamber mesh (or all frame if not found)
  if(uiSelectedTool !== toolId || chamberMesh){
    syncThreeSelection(toolId, chamberMesh || null);
  }
  uiSelectedTool = toolId;
  uiSelectedChamber = { toolId, frame, chamber };
  uiExpandedTools.add(toolId);

  // Populate state C header
  document.getElementById('rp-ch-id').textContent = chamber;
  document.getElementById('rp-ch-sub').textContent = '';
  document.getElementById('rp-ch-back').textContent = `← ${toolId}`;

  // Populate state C body
  const scroll = document.getElementById('rp-c-scroll');
  const chamberType = meta.chamberTypes?.[chamber] || '—';

  // ── Chamber info ────────────────────────────────────────────
  const chamberSection = `<div class="pane-sec">
    <div class="pane-sec-hd">Chamber</div>
    <div class="meta-row">
      <span class="meta-lbl">Type</span>
      <span class="meta-val">${chamberType}</span>
    </div>
    <div class="meta-row">
      <span class="meta-lbl">Frame</span>
      <span class="meta-val">${frame}</span>
    </div>
  </div>`;

  // ── Workstation ─────────────────────────────────────────────
  const wsSection = `<div class="pane-sec">
    <div class="pane-sec-hd">Workstation</div>
    <div class="ws-block">
      <div class="ws-icon">
        <svg width="15" height="15" viewBox="0 0 15 15" fill="none">
          <rect x="1" y="2" width="13" height="9" rx="1.5" stroke="#0078D4" stroke-width="1.2"/>
          <line x1="5.5" y1="11" x2="5.5" y2="14" stroke="#0078D4" stroke-width="1.2"/>
          <line x1="9.5" y1="11" x2="9.5" y2="14" stroke="#0078D4" stroke-width="1.2"/>
          <line x1="3.5" y1="14" x2="11.5" y2="14" stroke="#0078D4" stroke-width="1.2" stroke-linecap="round"/>
        </svg>
      </div>
      <div>
        <div class="ws-lbl">Workstation ID</div>
        <div class="ws-name">${meta.workstation}</div>
      </div>
    </div>
  </div>`;

  // Resolve owner: chamber-specific if defined, else inherit from frame
  const chamberSpecificOwners = meta.chamberOwners?.[chamber];
  const resolvedOwners = chamberSpecificOwners || meta.owners;
  const ownerLabel = chamberSpecificOwners ? 'Equipment Owner' : 'Equipment Owner <span style="font-size:var(--fs-xs);font-weight:400;color:var(--txt-muted);text-transform:none;letter-spacing:0">(frame)</span>';

  // ── Equipment Owner ─────────────────────────────────────────
  const contactSection = `<div class="pane-sec">
    <div class="pane-sec-hd">${ownerLabel}</div>
    ${resolvedOwners.map(o => `
      <div class="contact-row">
        <div class="contact-ico">👤</div>
        <div style="min-width:0">
          <div class="contact-name">${o.name}</div>
          <div class="contact-detail">
            ${o.email ? `<a href="mailto:${o.email}">${o.email}</a>` : '—'}
            ${o.phone ? ` · ${o.phone}` : ''}
          </div>
        </div>
      </div>`).join('')}
  </div>`;

  // ── References ──────────────────────────────────────────────
  const linksSection = `<div class="pane-sec">
    <div class="pane-sec-hd">References</div>
    <div class="link-list">
      <a href="#" class="link-row" target="_blank" rel="noopener">
        <div class="link-ico ico-sop">SOP</div>
        <div class="link-body"><div class="link-title">PM Procedure</div></div>
        <div class="link-chev">↗</div>
      </a>
      <a href="#" class="link-row" target="_blank" rel="noopener">
        <div class="link-ico ico-jha">JHA</div>
        <div class="link-body"><div class="link-title">Job Hazard Analysis</div></div>
        <div class="link-chev">↗</div>
      </a>
      <a href="#" class="link-row" target="_blank" rel="noopener">
        <div class="link-ico ico-ref">REF</div>
        <div class="link-body"><div class="link-title">EIP / Drawings</div></div>
        <div class="link-chev">↗</div>
      </a>
      <a href="#" class="link-row" target="_blank" rel="noopener">
        <div class="link-ico ico-photo">IMG</div>
        <div class="link-body"><div class="link-title">Chamber Photos</div></div>
        <div class="link-chev">↗</div>
      </a>
    </div>
  </div>`;

  scroll.innerHTML = chamberSection + wsSection + contactSection + linksSection;

  renderLeftPanel();
  setRpState('c');
}

function syncThreeSelection(targetId, hitMesh=null){
  // Return any previously lifted chamber to its base
  if(selChamberMesh){ prevChamberMesh=selChamberMesh; selChamberMesh=null; }
  // Restore all previously highlighted part meshes
  selectedMeshes.forEach(m => applyMats(m, 0, false));
  selectedMeshes.clear();
  // Lower the previous group
  if(selGroup){ selGroup.userData.liftActive=false; selGroup=null; }
  if(!targetId) return;

  const group=toolGroups.get(targetId);
  if(!group) return;

  // Highlight scope:
  //   chamber hit  → only that mesh
  //   frame hit OR panel/list select (no hitMesh) → all frame-typed parts of the tool
  const isChamberClick = hitMesh && hitMesh.userData.partType?.startsWith('chamber_');
  const toHL = isChamberClick
    ? [hitMesh]
    : TM.filter(m => TD.get(m)?.id===targetId && TD.get(m)?.partType==='frame');
  toHL.forEach(m=>{ selectedMeshes.add(m); applyMats(m,0,true); });

  // If a chamber part was hit, queue it for individual lift
  if(hitMesh && hitMesh.userData.localBaseY !== undefined){
    selChamberMesh=hitMesh;
  }

  // Draw HUD label for the primary selected mesh
  const labelMesh = hitMesh || toHL[0] || null;
  if(labelMesh) _drawSelLabel(_getSelLabelText(labelMesh, targetId));

  selGroup=group;
  selGroup.userData.liftActive=true;
  flyToTool(group);
}

// Back / deselect (state B)
document.getElementById('rp-sel-back').addEventListener('click', () => {
  syncThreeSelection(null);
  uiSelectedTool = null;
  uiSelectedChamber = null;
  uiExpandedTools.clear();
  renderLeftPanel();
  setRpState('a');
  clearReturnHome();
  O.flyFrom={tgt:O.tgt.clone(),phi:O.phi,r:O.r,theta:O.theta};
  O.flyGoal={tgt:HOME.tgt.clone(),phi:HOME.phi,r:HOME.r,theta:HOME.theta};
  O.flyDur=700;O.flyT=0;O.flyActive=true;
});

// Back to tool (state C)
document.getElementById('rp-ch-back').addEventListener('click', () => {
  if(!uiSelectedTool) { setRpState('a'); return; }
  uiSelectedChamber = null;
  const toolEntry = D.tools.find(t => t.id === uiSelectedTool);
  if(toolEntry){
    const row = RM.get(toolEntry.ri);
    if(row){
      const data = {id:uiSelectedTool, vendor:D.vn[toolEntry.v], bld:row.b, row:row.n, side:toolEntry.s, v:toolEntry.v};
      renderToolPanel(uiSelectedTool, data);
      renderLeftPanel();
      setRpState('b');
      return;
    }
  }
  setRpState('a');
});

// Breadcrumb tool link in state C — also goes back to tool

// ============================================================
// SEARCH
// ============================================================
document.getElementById('search-input').addEventListener('input', e => {
  uiSearch = e.target.value;
  renderLeftPanel();
});

// ============================================================
// DRAWER (standard mode)
// ============================================================
const drawer = document.getElementById('left-drawer');
const backdrop = document.getElementById('drawer-backdrop');

document.getElementById('nav-drawer-btn').addEventListener('click', () => {
  drawer.classList.add('open'); backdrop.classList.add('open'); renderDrawerList();
});
document.getElementById('drawer-close-btn').addEventListener('click', () => {
  drawer.classList.remove('open'); backdrop.classList.remove('open');
});
backdrop.addEventListener('click', () => {
  drawer.classList.remove('open'); backdrop.classList.remove('open');
});
document.getElementById('drawer-search').addEventListener('input', e => {
  uiDrawerSearch = e.target.value; renderDrawerList();
});

function renderDrawerList(){
  const q = uiDrawerSearch.toLowerCase();
  const drawerList = document.getElementById('drawer-tool-list');
  let html = '';
  D.tools.forEach(t => {
    if(q && !t.id.toLowerCase().includes(q)) return;
    const row = RM.get(t.ri); if(!row) return;
    const isSel = t.id === uiSelectedTool;
    html += `<div class="tool-row${isSel?' sel':''}" data-id="${t.id}" data-v="${t.v}" data-bld="${row.b}" data-row="${row.n}" data-side="${t.s}">
      <div class="t-vendor-bar ${t.v}"></div>
      <div class="t-info">
        <div class="t-id${isSel?' sel-id':''}">${t.id}</div>
        <div class="t-loc">${BLDG_LABELS[row.b]||row.b} · Row ${row.n}</div>
      </div>
    </div>`;
  });
  if(!html) html = `<div style="padding:20px 13px;font-size:15px;color:var(--txt-muted)">No tools match.</div>`;
  drawerList.innerHTML = html;
  drawerList.querySelectorAll('.tool-row').forEach(el => {
    el.addEventListener('click', () => {
      const id = el.dataset.id;
      const data = {id, vendor:D.vn[el.dataset.v], bld:el.dataset.bld, row:el.dataset.row, side:el.dataset.side, v:el.dataset.v};
      syncThreeSelection(id); selectTool(id, data);
      drawer.classList.remove('open'); backdrop.classList.remove('open');
    });
  });
}

// ============================================================
// INITIAL RENDER
// ============================================================
renderLeftPanel();
</script>

