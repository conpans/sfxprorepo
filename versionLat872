function _drawSelLabel(text){
  const c = _lblCanvas, ctx = c.getContext('2d');
  ctx.clearRect(0,0,c.width,c.height);
  const r=16, pad=24, h=c.height-10;
  ctx.fillStyle='rgba(10,20,50,0.88)';
  ctx.strokeStyle='rgba(0,120,212,0.9)';
  ctx.lineWidth=3.5;
  ctx.beginPath();
  ctx.moveTo(pad+r,5); ctx.lineTo(c.width-pad-r,5);
  ctx.quadraticCurveTo(c.width-pad,5,c.width-pad,5+r);
  ctx.lineTo(c.width-pad,h-r);
  ctx.quadraticCurveTo(c.width-pad,h,c.width-pad-r,h);
  ctx.lineTo(pad+r,h);
  ctx.quadraticCurveTo(pad,h,pad,h-r);
  ctx.lineTo(pad,5+r);
  ctx.quadraticCurveTo(pad,5,pad+r,5);
  ctx.closePath(); ctx.fill(); ctx.stroke();
  ctx.font='700 48px -apple-system,BlinkMacSystemFont,sans-serif';
  ctx.fillStyle='#ffffff'; ctx.textAlign='center'; ctx.textBaseline='middle';
  ctx.fillText(text, c.width/2, c.height/2+1);
  _lblTex.needsUpdate = true;
}

