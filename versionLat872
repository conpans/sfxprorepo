  'AAEV832200': {
    workstation: 'WS-AAEV832200',
    owners: [{ name: 'See area lead', email: '', phone: '' }],
    frames: [{ label: 'MACH IV', chambers: ['AAEV832210', 'AAEV832220', 'AAEV832230', null] }],
    chamberTypes: {
      'AAEV832210': 'Process Chamber',
      'AAEV832220': 'Process Chamber',
      'AAEV832230': 'Process Chamber',
    },
    // chamberOwners: override the frame owner for specific chambers.
    // Any chamber NOT listed here inherits the top-level owners array.
    // chamberOwners: {
    //   'AAEV832210': [{ name: 'First Last', email: 'name@co.com', phone: 'x1234' }],
    //   'AAEV832220': [{ name: 'Other Person', email: 'other@co.com', phone: 'x5678' }],
